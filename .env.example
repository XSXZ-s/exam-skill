# Copy this file to .env and fill in your own values.
# .env is ignored by git and should never be committed.

LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com

# Optional: local embedding model used by Chroma indexing.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional: final context size and vector recall pool size.
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_K=10
RETRIEVAL_FETCH_K=30

# Optional: warn when selected files extract too little text.
MIN_EXTRACTED_CHARS=200

# Generation strategy. If estimated material tokens fit this budget, the app
# uses full-context generation first, then RAG/LLM coverage audit.
CONTEXT_WINDOW_TOKENS=64000
OUTPUT_TOKEN_RESERVE=12000
AUDIT_TOKEN_RESERVE=6000
FULL_CONTEXT_RATIO_PERCENT=55
AUDIT_MISSING_POINT_LIMIT=12

# Optional: keep HuggingFace model cache inside the project directory.
HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface/transformers
HF_HUB_CACHE=.cache/huggingface/hub
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# HuggingFace model download endpoint.
# Default: domestic mirror. If it fails and you have VPN/proxy, switch to the official source below.
HF_ENDPOINT=https://hf-mirror.com
# HF_ENDPOINT=https://huggingface.co
